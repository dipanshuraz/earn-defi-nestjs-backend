{
  "name": "defi-earn-backend",
  "version": "0.1.0",
  "description": "Production-ready backend for a DeFi Earn platform",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "integration:testnet": "node scripts/run-testnet-earn-flow.mjs",
    "prisma:generate": "node scripts/prisma-env.mjs generate",
    "prisma:migrate:dev": "node scripts/prisma-env.mjs migrate:dev",
    "prisma:migrate:deploy": "node scripts/prisma-env.mjs migrate:deploy",
    "prisma:studio": "node scripts/prisma-env.mjs studio",
    "db:generate": "npm run prisma:generate",
    "db:migrate:local": "APP_ENV=local node scripts/prisma-env.mjs migrate:dev",
    "db:migrate:develop": "APP_ENV=develop node scripts/prisma-env.mjs migrate:dev",
    "db:deploy:local": "APP_ENV=local node scripts/prisma-env.mjs migrate:deploy",
    "db:deploy:develop": "APP_ENV=develop node scripts/prisma-env.mjs migrate:deploy",
    "db:deploy:production": "APP_ENV=production node scripts/prisma-env.mjs migrate:deploy",
    "db:status": "node scripts/prisma-env.mjs migrate:status",
    "db:status:local": "APP_ENV=local node scripts/prisma-env.mjs migrate:status",
    "db:status:develop": "APP_ENV=develop node scripts/prisma-env.mjs migrate:status",
    "db:status:production": "APP_ENV=production node scripts/prisma-env.mjs migrate:status",
    "db:reset:local": "APP_ENV=local node scripts/prisma-env.mjs migrate:reset",
    "db:reset:develop": "APP_ENV=develop node scripts/prisma-env.mjs migrate:reset",
    "db:reset:production": "APP_ENV=production node scripts/prisma-env.mjs migrate:reset",
    "db:baseline:init": "node scripts/prisma-env.mjs migrate:resolve --applied 20250611000000_init"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "@privy-io/node": "^0.21.0",
    "@upstash/redis": "^1.38.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.2.0",
    "joi": "^17.13.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
