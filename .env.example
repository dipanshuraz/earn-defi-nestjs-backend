# Application
NODE_ENV=development
APP_ENV=local
PORT=3000
API_PREFIX=api/v1
CORS_ORIGINS=*
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
MAX_DEPOSITS_PER_MINUTE=10
MAX_WITHDRAWALS_PER_MINUTE=10
DEPENDENCY_CHECK_TIMEOUT_MS=5000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/defi_earn?schema=public

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
REDIS_URL=rediss://default:your-upstash-token@your-instance.upstash.io:6379
QUEUE_ENABLED=true

# Blockchain (Alchemy)
ALCHEMY_API_KEY=your-alchemy-api-key
CHAIN=base-sepolia
CHAIN_ID=84532
MAINNET_ENABLED=false
ALLOW_MAINNET_TRANSACTIONS=false
RPC_URL=https://base-sepolia.g.alchemy.com/v2/your-alchemy-api-key

# Auth (Privy)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your-privy-app-id/jwks.json
# Server-side wallet tx signing (see docs/privy-server-signing.md)
PRIVY_AUTHORIZATION_PRIVATE_KEY=wallet-auth:your-base64-pkcs8-private-key
PRIVY_WALLET_SIGNER_KEY_QUORUM_ID=your-key-quorum-id

# Auth (JWT)
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# Wallets
WALLET_PROVIDER=privy

# Chains & Assets (JSON arrays — use ${ALCHEMY_API_KEY} interpolation in rpcUrl)
CHAINS_CONFIG=[{"slug":"base-sepolia","name":"Base Sepolia","chainId":84532,"isTestnet":true,"isEnabled":true,"rpcUrl":"https://base-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}","explorerUrl":"https://sepolia.basescan.org","nativeCurrency":{"name":"Ether","symbol":"ETH","decimals":18}},{"slug":"base","name":"Base","chainId":8453,"isTestnet":false,"isEnabled":true,"rpcUrl":"https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}","explorerUrl":"https://basescan.org","nativeCurrency":{"name":"Ether","symbol":"ETH","decimals":18}}]
ASSETS_CONFIG=[{"symbol":"ETH","name":"Ether","chainId":84532,"contractAddress":"native","decimals":18,"isEnabled":true},{"symbol":"USDC","name":"USD Coin","chainId":84532,"contractAddress":"0xba50Cd2A20f6DA35D788639E581bca8d0B5d4D5f","decimals":6,"isEnabled":true},{"symbol":"ETH","name":"Ether","chainId":8453,"contractAddress":"native","decimals":18,"isEnabled":true},{"symbol":"USDC","name":"USD Coin","chainId":8453,"contractAddress":"0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913","decimals":6,"isEnabled":true}]

# Earn Protocols (Aave V3)
EARN_PROTOCOL_PROVIDER=aave
AAVE_API_URL=https://api.v3.aave.com/graphql
AAVE_VAULTS_CONFIG=[{"vaultId":"aave-base-sepolia-usdc","chainId":84532,"poolAddress":"0x8bAB6d1b75f19e9eD9fCe8b9BD338844fF79aE27","aTokenAddress":"0x10F1A9D11CDf50041f3f8cB7191CBE2f31750ACC","assetSymbol":"USDC","assetAddress":"0xba50Cd2A20f6DA35D788639E581bca8d0B5d4D5f","isEnabled":true},{"vaultId":"aave-base-usdc","chainId":8453,"poolAddress":"0xA238Dd80C259a72e81d7e4664a9801593F98d1c5","aTokenAddress":"0x4e65fE4DbA92790696d040ac24Aa414708F5c0AB","assetSymbol":"USDC","assetAddress":"0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913","isEnabled":false}]

# Idempotency
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_HEADER_NAME=idempotency-key
